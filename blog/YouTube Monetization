        <img src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhTHxcqxW1PmiJgZ8SNzREij2FO0EGE1h1Bn9lMZRkM0b5Pgj5WxXfXOhm21LJJ9hHJmT4ldDZukdq45i90L0yU6V1LmJJJP2JaaTXZsr7l1aF-iq-Uj5HKFkeCOiQ49zxpPke3Owarp7KB2B0F_JTP3ETTT3xAP4tIdBem2HlxjciC3G9DZJ0hP5ghL44/s16000/1000256345.jpg" alt="Understanding YouTube Audience Retention Graph">
